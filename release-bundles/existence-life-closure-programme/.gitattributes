# Treat all PDFs and figures as binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary

# Normalise line endings on text source files
*.tex text eol=lf
*.bib text eol=lf
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.cff text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Linguistic detection: prefer LaTeX/Python over the lump of figures + PDFs
*.pdf linguist-detectable=false
*.png linguist-detectable=false
papers/*/paper.pdf linguist-generated=true
notes/*/note.pdf linguist-generated=true
